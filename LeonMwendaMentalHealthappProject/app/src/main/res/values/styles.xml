<resources>
    <style name="Theme.MindCare" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:fontFamily">monospace</item>
        <item name="fontFamily">monospace</item>
        <item name="colorPrimary">@color/jet_black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/calm_green</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="MindCard">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="android:layout_margin">8dp</item>
    </style>
</resources>
