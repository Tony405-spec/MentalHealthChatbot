<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Emergency Support" android:textColor="@color/jet_black" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="If you may hurt yourself or someone else, call local emergency services now." android:textColor="@color/jet_black" android:textSize="15sp" android:layout_marginTop="12dp" android:background="@drawable/bg_rounded_soft" />
        <com.google.android.material.button.MaterialButton android:id="@+id/callEmergency" android:layout_width="match_parent" android:layout_height="56dp" android:text="Call Emergency Services" android:backgroundTint="@color/jet_black" android:textColor="@color/white" android:layout_marginTop="16dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mental health hotlines\nKenya Red Cross: 1199\nBefrienders Kenya: +254 722 178 177\nUS 988 Lifeline: Call or text 988\nSamaritans: 116 123\n\nProfessional resources\nSpeak with a licensed therapist, counselor, physician, campus wellness office, or trusted local mental health clinic." android:textColor="@color/muted_text" android:textSize="15sp" android:lineSpacingExtra="6dp" android:layout_marginTop="18dp" />
    </LinearLayout>
</ScrollView>
