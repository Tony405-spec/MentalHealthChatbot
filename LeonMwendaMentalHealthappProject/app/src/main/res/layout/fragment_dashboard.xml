<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:id="@+id/dashboardRoot" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView android:id="@+id/welcomeText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Good day" android:textColor="@color/jet_black" android:textSize="26sp" android:textStyle="bold" />
        <TextView android:id="@+id/quoteText" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/muted_text" android:textSize="14sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="18dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/quickMood" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="Mood" android:backgroundTint="@color/jet_black" android:textColor="@color/white" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/quickJournal" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="Journal" android:backgroundTint="@color/jet_black" android:textColor="@color/white" />
        </LinearLayout>
        <com.google.android.material.card.MaterialCardView style="@style/MindCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:backgroundTint="@color/soft_grey">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="18dp" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mood summary" android:textColor="@color/jet_black" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:id="@+id/moodSummary" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="No mood entries yet. Start with one gentle check-in." android:textColor="@color/muted_text" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView style="@style/MindCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:backgroundTint="@color/soft_grey">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="18dp" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Support Us / Donate" android:textColor="@color/jet_black" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Help keep MindCare accessible through a secure M-Pesa contribution." android:textColor="@color/muted_text" android:layout_marginTop="6dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Safaricom phone e.g. 254712345678" android:layout_marginTop="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/donatePhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Amount KES" android:layout_marginTop="8dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/donateAmount" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton android:id="@+id/donateButton" android:layout_width="match_parent" android:layout_height="52dp" android:text="Donate with M-Pesa" android:backgroundTint="@color/jet_black" android:textColor="@color/white" android:layout_marginTop="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.button.MaterialButton android:id="@+id/chatShortcut" android:layout_width="match_parent" android:layout_height="56dp" android:text="Talk to Care AI" android:textColor="@color/jet_black" android:backgroundTint="@color/calm_green" android:layout_marginTop="12dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/supportShortcut" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="Emergency Help" android:textColor="@color/jet_black" android:backgroundTint="@color/soft_grey" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/profileShortcut" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="Profile" android:textColor="@color/jet_black" android:backgroundTint="@color/soft_grey" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
